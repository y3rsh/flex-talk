{
  "name": "@y3rsh/flex-tools-core",
  "version": "0.1.0",
  "description": "Framework-agnostic tool definitions for Opentrons Flex",
  "license": "MIT",
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && node ./scripts/postbuild.mjs",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@y3rsh/flex-client": ">=0.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^5.8.3"
  }
}
