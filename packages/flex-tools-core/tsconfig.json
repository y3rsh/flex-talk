{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "declarationDir": "dist/types",
    "sourceMap": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "rootDir": "src",
    "skipLibCheck": true
  },
  "include": ["src"]
}
