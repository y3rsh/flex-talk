{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "types": ["@cloudflare/workers-types"],
    "lib": ["ES2022", "WebWorker"],
    "skipLibCheck": true
  },
  "include": ["src"]
}
